<SectionList>:
    MDBoxLayout:
        orientation: "vertical"
        spacing: 0
        padding: 0

        MDTopAppBar:
            title: "Sections"
            left_action_items: [["arrow-left", lambda x: app.nav.event_form("right")]]

            MDLabel:
                text: f"{root.event.name} - {root.event.date}" if root.event else "Sections"
                # pos_hint: {"center_x": 0.5, "center_y": 0.2}
                size_hint_y: None
                height: dp(20)

        MDLabel:
            text: "No boards for this event"
            halign: "center"
            size_hint_y: None
            height: dp(48) if len(root.boards) == 0 else dp(0)
            opacity: 1 if len(root.boards) == 0 else 0
            disabled: True if len(root.boards) > 0 else False

        ScrollView:
            do_scroll_x: False
            MDList:
                id: section_list
                size_hint_y: None
                height: self.minimum_height
