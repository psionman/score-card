<EventList>:
    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Events"
            # title: root.db_path
            right_action_items: [["dots-vertical", lambda x: root.open_menu(x)]]

        ScrollView:
            MDList:
                id: event_list

        MDFloatingActionButton:
            icon: "plus"
            pos_hint: {"right": 0.95, "y": 0.05}
            on_release: root.go_event_form()

<Divider>:
    canvas:
        Color:
            rgba: 0.5, 0.5, 0.5, 0.3
        Rectangle:
            pos: self.pos
            size: self.size
