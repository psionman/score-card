# kv/score_picker.kv

<ScorePicker>:
    orientation: "vertical"
    spacing: dp(8)
    padding: dp(8)
    size_hint_y: None
    height: self.minimum_height

    GridLayout:
        cols: 1
        spacing: dp(4)
        size_hint: 1, None
        height: self.minimum_height
        pos_hint: {"center_x": 0.5}
        WhiteTextField:
            id: score
            hint_text: "Other score"
            readonly: True

    GridLayout:
        id: level_grid
        cols: 3
        spacing: dp(4)
        size_hint: 1, None
        height: self.minimum_height
        pos_hint: {"center_x": 0.5}

        SuitButton:
            text: "1"
            on_release: root.add_score_digit("1")
        SuitButton:
            text: "2"
            on_release: root.add_score_digit("2")
        SuitButton:
            text: "3"
            on_release: root.add_score_digit("3")
        SuitButton:
            text: "4"
            on_release: root.add_score_digit("4")
        SuitButton:
            text: "5"
            on_release: root.add_score_digit("5")
        SuitButton:
            text: "6"
            on_release: root.add_score_digit("6")
        SuitButton:
            text: "7"
            on_release: root.add_score_digit("7")
        SuitButton:
            text: "8"
            on_release: root.add_score_digit("8")
        SuitButton:
            text: "9"
            on_release: root.add_score_digit("9")
        SuitButton:
            text: "0"
            on_release: root.add_score_digit("0")
        SuitButton:
            text: "⌫"
            on_release: root.backspace()

    GridLayout:
        id: button_grid
        cols: 2
        size_hint_y: None
        height: dp(48)
        padding: dp(4)
        spacing: dp(8)

        MDFlatButton:
            text: "CANCEL"
            text_color: (0, 0, 0, 1)
            md_bg_color: (0.9, 0.9, 0.9, 1)
            size_hint_x: 0.5
            on_release: root.cancel()

        MDFlatButton:
            text: "DONE"
            text_color: (0, 0, 0, 1)
            md_bg_color: (0.9, 0.9, 0.9, 1)
            size_hint_x: 0.5
            on_release: root.confirm()
