# kv/lead_picker.kv

<LeadPicker>:
    orientation: "vertical"
    spacing: dp(8)
    padding: dp(8)
    size_hint_y: None
    height: self.minimum_height

    GridLayout:
        id: level_grid
        cols: 4
        spacing: dp(4)
        size_hint: 1, None
        height: self.minimum_height
        pos_hint: {"center_x": 0.5}

        SuitButton:
            text: "2"
            on_release: root.select_level("2")
        SuitButton:
            text: "3"
            on_release: root.select_level("3")
        SuitButton:
            text: "4"
            on_release: root.select_level("4")
        SuitButton:
            text: "5"
            on_release: root.select_level("5")
        SuitButton:
            text: "6"
            on_release: root.select_level("6")
        SuitButton:
            text: "7"
            on_release: root.select_level("7")
        SuitButton:
            text: "8"
            on_release: root.select_level("8")
        SuitButton:
            text: "9"
            on_release: root.select_level("9")
        SuitButton:
            text: "10"
            on_release: root.select_level("10")
        SuitButton:
            text: "J"
            on_release: root.select_level("J")
        SuitButton:
            text: "Q"
            on_release: root.select_level("Q")
        SuitButton:
            text: "K"
            on_release: root.select_level("K")
        SuitButton:
            text: "A"
            on_release: root.select_level("A")

    GridLayout:
        id: suit_grid
        cols: 4
        spacing: dp(2)
        size_hint: 1, None
        height: self.minimum_height
        pos_hint: {"center_x": 0.5}

        SuitButton:
            text: "♣"
            color: 0, 0, 0, 1
            on_release: root.select_suit("C", "♣")

        SuitButton:
            text: "♦"
            suit_color: 1, 0, 0, 1
            on_release: root.select_suit("D", "♦")

        SuitButton:
            text: "♥"
            suit_color: 1, 0, 0, 1
            on_release: root.select_suit("H", "♥")

        SuitButton:
            text: "♠"
            color: 0, 0, 0, 1
            on_release: root.select_suit("S", "♠")

    GridLayout:
        id: button_grid
        cols: 2
        size_hint_y: None
        height: dp(48)
        padding: dp(4)
        spacing: dp(8)

        MDFlatButton:
            text: "CANCEL"
            text_color: (0, 0, 0, 1)
            md_bg_color: (0.9, 0.9, 0.9, 1)
            size_hint_x: 0.5
            on_release: root.cancel()

        MDFlatButton:
            text: "DONE"
            text_color: (0, 0, 0, 1)
            md_bg_color: (0.9, 0.9, 0.9, 1)
            size_hint_x: 0.5
            on_release: root.confirm()
