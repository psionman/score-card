# kv/contract_picker.kv

<ContractPicker>:
    orientation: "vertical"
    spacing: dp(4)
    padding: dp(4)
    size_hint_x: 1


    GridLayout:
        id: level_grid
        cols: 4
        spacing: dp(4)
        size_hint: 1, None
        height: self.minimum_height

        SuitButton:
            text: "1"
            on_release: root.select_level("1")
        SuitButton:
            text: "2"
            on_release: root.select_level("2")
        SuitButton:
            text: "3"
            on_release: root.select_level("3")
        SuitButton:
            text: "4"
            on_release: root.select_level("4")
        SuitButton:
            text: "5"
            on_release: root.select_level("5")
        SuitButton:
            text: "6"
            on_release: root.select_level("6")
        SuitButton:
            text: "7"
            on_release: root.select_level("7")
        SuitButton:
            text: "P"
            color: 1, 1, 1, 1
            on_release: root.select_level("P")
            canvas.before:
                Color:
                    rgba: (0.2, 0.6, 0.2, 1) if self.state != "down" else (0.1, 0.4, 0.1, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]

        Widget:
            size_hint_y: None
            height: dp(8)


    GridLayout:
        id: suit_grid
        cols: 5
        spacing: dp(2)
        size_hint: 1, None
        height: self.minimum_height
        size: dp(5 * 48 + 4 * 2), dp(48)

        SuitButton:
            text: "♣"
            color: 0, 0, 0, 1
            on_release: root.select_suit("C", "♣")

        SuitButton:
            text: "♦"
            suit_color: 1, 0, 0, 1
            on_release: root.select_suit("D", "♦")

        SuitButton:
            text: "♥"
            suit_color: 1, 0, 0, 1
            on_release: root.select_suit("H", "♥")

        SuitButton:
            text: "♠"
            color: 0, 0, 0, 1
            on_release: root.select_suit("S", "♠")

        SuitButton:
            text: "NT"
            on_release: root.select_suit("NT", "NT")

        Widget:
            size_hint_y: None
            height: dp(8)

    GridLayout:
        id: doubled_grid
        cols: 3
        spacing: dp(4)
        size_hint: None, None
        size_hint: 1, None
        height: self.minimum_height

        SuitButton:
            text: "—"
            on_release: root.select_doubled("")

        SuitButton:
            text: "X"
            color: 1, 1, 1, 1
            on_release: root.select_doubled("X")
            canvas.before:
                Color:
                    rgba: (0.8, 0.2, 0.2, 1) if self.state != "down" else (0.4, 0.1, 0.1, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]

        SuitButton:
            text: "XX"
            color: 1, 1, 1, 1
            on_release: root.select_doubled("XX")
            canvas.before:
                Color:
                    rgba: (0.2, 0.2, 0.8, 1) if self.state != "down" else (0.1, 0.1, 0.4, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]

        Widget:
            size_hint_y: None
            height: dp(8)

    GridLayout:
        id:  button_grid
        cols: 2
        size_hint_y: None
        height: dp(48)
        padding: dp(4)      # was dp(8)
        spacing: dp(8)

        MDFlatButton:
            text: "CANCEL"
            text_color: (0, 0, 0, 1)
            md_bg_color: (0.9, 0.9, 0.9, 1)
            size_hint_x: 0.5
            on_release: root.cancel()

        MDFlatButton:
            text: "DONE"
            text_color: (0, 0, 0, 1)
            md_bg_color: (0.9, 0.9, 0.9, 1)
            size_hint_x: 0.5
            on_release: root.confirm()
