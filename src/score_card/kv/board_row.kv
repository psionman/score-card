<BoardRow>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(36)
    ripple_behavior: True

    MDLabel:
        text: str(root.board.board_number)
        halign: "center"

    MDLabel:
        text: str(root.board.score)
        halign: "center"

    MDLabel:
        text: str(root.board.team_score)
        halign: "center"

    MDLabel:
        text: str(root.board.imps)
        halign: "center"

<BoardHeader>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(36)

    MDLabel:
        text: "Board"
        halign: "center"

    MDLabel:
        text: "Score"
        halign: "center"

    MDLabel:
        text: "Team"
        halign: "center"

    MDLabel:
        text: "IMPs"
        halign: "center"
