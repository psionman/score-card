<SectionBoardList>:
    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Sections scores"
            left_action_items: [["arrow-left", lambda x: app.nav.section_list("right")]]
            right_action_items: [["content-save", lambda x: root.save_section()]]

            MDLabel:
                text: f"{root.event.name} - {root.event.date}" if root.event else "Sections scores"
                # pos_hint: {"center_x": 0.5, "center_y": 0.2}
                size_hint_y: None
                height: dp(20)

        ScrollView:
            do_scroll_x: False

            MDBoxLayout:
                id: board_list
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                size_hint_x: 1
                padding: dp(8)
                spacing: dp(4)
