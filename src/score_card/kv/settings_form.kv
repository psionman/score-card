# kv/settings_form.kv

<SettingsFormScreen>:
    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Settings"
            left_action_items: [["arrow-left", lambda x: app.nav.home()]]
            right_action_items: [["content-save", lambda x: root.save()]]

        MDBoxLayout:
            orientation: "vertical"
            padding: dp(40)
            spacing: dp(16)
            md_bg_color: BG


            MDBoxLayout:
                orientation: "vertical"
                padding: dp(40)
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height

                WhiteTextField:
                    id: email_input
                    hint_text: "Email address"
            Widget:  # 👈 THIS pushes everything above to the top
